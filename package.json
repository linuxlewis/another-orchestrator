{
  "name": "another-orchestrator",
  "version": "0.1.0",
  "packageManager": "pnpm@10.30.2",
  "type": "module",
  "bin": {
    "orchestrator": "./dist/cli.js"
  },
  "files": [
    "dist",
    "workflows",
    "prompts",
    "scripts",
    "skills"
  ],
  "scripts": {
    "build": "tsc && node scripts/link-skills.js",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "fast-xml-parser": "^5.7.1",
    "nunjucks": "^3.2.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "turndown": "^7.2.4",
    "yaml": "^2.7.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/node": "^22.13.4",
    "@types/nunjucks": "^3.2.6",
    "@types/pino-pretty": "^5.0.0",
    "@types/turndown": "^5.0.6",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  }
}
